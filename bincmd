#!/data/data/com.termux/files/usr/bin/bash

echo "🧹 Cleaning up project junk..."

# Define root (you can change this if needed)
PROJECT_DIR=/sdcard/Elparadisogonzalo/Elparadisogonzalo.github.io

# List of patterns to remove
JUNK=(
  "node_modules"
  ".next"
  ".turbo"
  "dist"
  ".cache"
  ".eslintcache"
  "build"
)

# delete each target
for junk in "${JUNK[@]}"; do
  echo "🚮 Removing: $junk"
  find "$PROJECT_DIR" -type d -name "$junk" -prune -exec rm -rf {} +
done

echo "✅ Cleanup complete."
